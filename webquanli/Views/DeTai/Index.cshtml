@model List<webquanli.Models.DeTai>
@{
    ViewData["Title"] = "Danh sách Đề tài";
}

<div class="d-sm-flex align-items-center justify-content-between mb-4">
    <h1 class="h3 mb-0 text-gray-800">Quản lý Đề tài</h1>
    <a href="/DeTai/Create" class="btn btn-primary shadow-sm">
        <i class="fa-solid fa-plus fa-sm text-white-50"></i> Thêm đề tài mới
    </a>
</div>

<div class="card shadow mb-4">
    <div class="card-header py-3">
        <h6 class="m-0 font-weight-bold text-primary">Danh mục Đề tài Đồ án/Luận văn</h6>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-bordered table-hover" id="dataTable" width="100%" cellspacing="0">
                <thead class="table-light">
                    <tr>
                        <th style="width: 30%;">Tên đề tài</th>
                        <th>Mô tả tóm tắt</th>
                        <th class="text-center" style="width: 150px;">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var dt in Model)
                        {
                            <tr>
                                <td class="align-middle fw-bold text-primary">@dt.TenDeTai</td>
                                <td class="align-middle text-muted">@dt.MoTa</td>
                                <td class="text-center align-middle">
                                    <a class="btn btn-warning btn-sm" href="/DeTai/Edit/@dt.Id" title="Sửa"><i class="fa-solid fa-pen-to-square"></i></a>
                                    <a class="btn btn-danger btn-sm" href="/DeTai/Delete/@dt.Id" title="Xóa"><i class="fa-solid fa-trash"></i></a>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#dataTable').DataTable({ "language": { "url": "//cdn.datatables.net/plug-ins/1.13.6/i18n/vi.json" } });
        });
    </script>
}