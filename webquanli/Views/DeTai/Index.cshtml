@model List<webquanli.Models.DeTai>
@using webquanli.Data
@inject ApplicationDbContext _context
@{
    ViewData["Title"] = "Danh sách Đề Tài";
    
    // Lấy túi Dictionary đã đóng gói từ Controller
    var dictDangKy = ViewBag.DictDangKy as Dictionary<int, webquanli.Models.DangKyDeTai> ?? new Dictionary<int, webquanli.Models.DangKyDeTai>();
    int deTaiCuaToi = ViewBag.DeTaiCuaToi != null ? (int)ViewBag.DeTaiCuaToi : 0;

    string realRole = "";
    int? currentGvId = null;

    if (User.Identity.IsAuthenticated)
    {
        var currentUser = _context.Users.FirstOrDefault(u => u.Username == User.Identity.Name);
        if (currentUser != null)
        {
            realRole = currentUser.Role?.Trim().ToLower() ?? "";
            currentGvId = currentUser.GiangVienId;
        }
    }
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show shadow-sm border-0" role="alert" style="background-color: #e5f8ed; color: #00b050;">
        <i class="fa-solid fa-circle-check"></i> <strong>Tuyệt vời!</strong> @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show shadow-sm border-0" role="alert" style="background-color: #ffe8eb; color: #f1416c;">
        <i class="fa-solid fa-triangle-exclamation"></i> <strong>Không thành công:</strong> @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="card shadow mb-4">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h6 class="m-0"><i class="fa-solid fa-book-open text-primary me-2"></i> DANH SÁCH ĐỀ TÀI ĐỒ ÁN</h6>
        @if (realRole == "giangvien")
        {
            <a asp-action="Create" class="btn btn-primary btn-sm shadow-sm">
                <i class="fa-solid fa-plus me-1"></i> Thêm đề tài mới
            </a>
        }
    </div>

    <div class="card-body bg-light border-bottom" style="border-radius: 0;">
        <div class="row align-items-center">
            <div class="col-md-6 d-flex justify-content-md-end align-items-center w-100">
                <label class="me-2 fw-bold text-muted" style="font-size: 0.85rem;"><i class="fa-solid fa-filter"></i> Khoa/Bộ môn:</label>
                <select id="filterBoMon" class="form-select shadow-sm border-0" style="width: 270px; font-size: 0.9rem; border-radius: 8px;">
                    @if (realRole == "admin")
                    {
                        <option value="none" selected>-- Vui lòng chọn Bộ môn --</option>
                    }
                    else
                    {
                        <option value="" selected>-- Tất cả --</option>
                    }
                </select>
            </div>
        </div>
    </div>

    @if (realRole == "admin")
    {
        <div id="emptyState" class="text-center py-5">
            <i class="fa-solid fa-folder-tree text-primary mb-3" style="font-size: 5rem; opacity: 0.2;"></i>
            <h5 class="fw-bold text-secondary">Chưa chọn Khoa / Bộ môn</h5>
            <p class="text-muted mb-0">Hệ thống có rất nhiều đề tài. Để bảng dữ liệu không bị quá tải,<br>vui lòng chọn một Bộ môn ở góc trên bên phải để hiển thị danh sách nhé!</p>
        </div>
    }

    <div class="table-responsive" id="tableWrapper" style="@(realRole == "admin" ? "display: none;" : "") padding-top: 15px;">
        <table class="table table-hover align-middle" id="dataTable" width="100%" cellspacing="0">
            <thead class="table-light text-muted" style="font-size: 0.85rem;">
                <tr>
                    <th style="width: 5%;">ID</th>
                    <th style="width: 30%;">Tên Đề Tài</th>
                    <th style="width: 25%;">Giảng Viên</th>
                    <th class="text-center" style="width: 20%;">Trạng thái</th>
                    <th class="text-center" style="width: 20%;">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var dt in Model)
                    {
                        bool isTaken = dictDangKy.ContainsKey(dt.Id);
                        var thongTinDangKy = isTaken ? dictDangKy[dt.Id] : null;
                        bool isMine = isTaken && (dt.Id == deTaiCuaToi);

                        <tr>
                            <td class="fw-bold text-muted">@dt.Id</td>
                            
                            <td>
                                <div class="fw-bold text-primary mb-1">@dt.TenDeTai</div>
                                <div class="text-muted text-truncate" data-bs-toggle="tooltip" data-bs-placement="top" title="@dt.MoTa" style="max-width: 250px; font-size: 0.8rem; cursor: help;">
                                    @dt.MoTa
                                </div>
                            </td>

                            <td>
                                <span class="badge bg-secondary mb-1">@(dt.GiangVien != null ? dt.GiangVien.TenGV : "Chưa phân công")</span><br />
                                <small class="text-muted fw-bold bomon-text">@(dt.GiangVien?.BoMon?.TenBoMon)</small>
                            </td>
                            
                            <td class="text-center">
                                @if (isTaken)
                                {
                                    if (thongTinDangKy.IsApproved)
                                    {
                                        <span class="badge bg-success bg-opacity-10 text-success border border-success mb-1"><i class="fa-solid fa-lock"></i> Đã chốt</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning bg-opacity-10 text-warning border border-warning mb-1"><i class="fa-solid fa-hourglass-half"></i> Chờ duyệt</span>
                                    }
                                    <div class="small fw-bold text-dark mt-1">SV: @thongTinDangKy.SinhVien.TenSV</div>
                                }
                                else
                                {
                                    <span class="badge border border-success text-success bg-light"><i class="fa-regular fa-circle-check"></i> Còn trống</span>
                                }
                            </td>

                            <td class="text-center">
                                @if (realRole == "sinhvien")
                                {
                                    if (isMine)
                                    {
                                        <div class="d-flex flex-column align-items-center gap-2">
                                            @if (thongTinDangKy.IsApproved)
                                            {
                                                <span class="badge bg-success shadow-sm w-100 py-2"><i class="fa-solid fa-shield-check"></i> Đã được duyệt</span>
                                            }
                                            else
                                            {
                                                <form asp-action="HuyDangKy" asp-route-id="@dt.Id" method="post" class="w-100">
                                                    <button type="submit" class="btn btn-outline-danger btn-sm fw-bold w-100" onclick="return confirm('Bạn có chắc muốn rút lại yêu cầu?')">Hủy yêu cầu</button>
                                                </form>
                                            }
                                        </div>
                                    }
                                    else if (!isTaken)
                                    {
                                        if (deTaiCuaToi > 0)
                                        {
                                            <button class="btn btn-light text-muted btn-sm fw-bold w-100" disabled><i class="fa-solid fa-ban"></i> Đã chọn đề tài khác</button>
                                        }
                                        else
                                        {
                                            <form asp-action="DangKy" asp-route-id="@dt.Id" method="post">
                                                <button type="submit" class="btn btn-primary btn-sm fw-bold shadow-sm w-100" onclick="return confirm('Xác nhận nộp yêu cầu đăng ký đề tài này?')">
                                                    <i class="fa-solid fa-hand-pointer"></i> Đăng ký
                                                </button>
                                            </form>
                                        }
                                    }
                                    else
                                    {
                                        <button class="btn btn-light text-muted btn-sm fw-bold w-100" disabled><i class="fa-solid fa-user-lock"></i> Đã có người chọn</button>
                                    }
                                }
                                else if (realRole == "giangvien" && dt.GiangVienId == currentGvId)
                                {
                                    <div class="dropdown">
                                        <button class="btn btn-light btn-sm shadow-sm border" type="button" data-bs-toggle="dropdown" aria-expanded="false" style="border-radius: 8px;">
                                            <i class="fa-solid fa-ellipsis-vertical px-2"></i>
                                        </button>
                                        <ul class="dropdown-menu dropdown-menu-end shadow-sm border-0" style="border-radius: 10px;">
                                            
                                            @if (isTaken)
                                            {
                                                if (!thongTinDangKy.IsApproved)
                                                {
                                                    <li>
                                                        <form asp-action="PheDuyet" asp-route-id="@dt.Id" method="post">
                                                            <button type="submit" class="dropdown-item text-success fw-bold py-2"><i class="fa-solid fa-check text-center me-2" style="width: 20px;"></i> Phê duyệt sinh viên này</button>
                                                        </form>
                                                    </li>
                                                }
                                                else
                                                {
                                                    <li>
                                                        <form asp-action="GoDuyet" asp-route-id="@dt.Id" method="post" onsubmit="return confirm('Bạn có chắc muốn gỡ đề tài của sinh viên này? Toàn bộ báo cáo của sinh viên này sẽ bị mất!')">
                                                            <button type="submit" class="dropdown-item text-danger fw-bold py-2"><i class="fa-solid fa-user-xmark text-center me-2" style="width: 20px;"></i> Gỡ duyệt (Cho đổi đề tài)</button>
                                                        </form>
                                                    </li>
                                                }
                                                <li><hr class="dropdown-divider"></li>
                                            }

                                            <li><a class="dropdown-item text-primary fw-bold py-2" asp-action="Edit" asp-route-id="@dt.Id"><i class="fa-solid fa-pen text-center me-2" style="width: 20px;"></i> Chỉnh sửa mô tả</a></li>
                                            @if (!isTaken)
                                            {
                                                <li><hr class="dropdown-divider"></li>
                                                <li><a class="dropdown-item text-danger fw-bold py-2" asp-action="Delete" asp-route-id="@dt.Id" onclick="return confirm('Bạn có chắc chắn xóa đề tài này?')"><i class="fa-solid fa-trash text-center me-2" style="width: 20px;"></i> Xóa đề tài</a></li>
                                            }
                                        </ul>
                                    </div>
                                }
                                else
                                {
                                    <span class="badge bg-light text-muted border py-2 px-3 shadow-sm" title="Chỉ giảng viên phụ trách mới có quyền sửa đổi"><i class="fa-solid fa-lock me-1"></i> Khóa</span>
                                }
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            var table = $('#dataTable').DataTable({
                "language": { "url": "//cdn.datatables.net/plug-ins/1.13.6/i18n/vi.json" },
                "pageLength": 10,
                "dom": '<"row mb-3"<"col-md-6"l><"col-md-6"f>>rt<"row mt-3"<"col-md-5"i><"col-md-7"p>>'
            });

            var dsBoMon = new Set();
            $('.bomon-text').each(function() {
                var tenBM = $(this).text().trim();
                if(tenBM && tenBM !== "") { dsBoMon.add(tenBM); }
            });
            dsBoMon.forEach(function(bm) {
                $('#filterBoMon').append('<option value="'+bm+'">'+bm+'</option>');
            });

            @if (realRole == "admin")
            {
                        <text>
                                    $('#filterBoMon').on('change', function() {
                                        var val = $(this).val();
                                        if (val === "none") {
                                            $('#tableWrapper').hide();
                                            $('#emptyState').fadeIn(); // Hiện trạng thái chờ
                                        } else {
                                            $('#emptyState').hide();   // Ẩn trạng thái chờ
                                            $('#tableWrapper').fadeIn();
                                            table.column(2).search(val).draw();
                                        }
                                    });
                        </text>
            }
            else
            {
                        <text>
                                    $('#filterBoMon').on('change', function() {
                                        var val = $(this).val();
                                        table.column(2).search(val).draw();
                                    });
                        </text>
            }

            var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'))
            var tooltipList = tooltipTriggerList.map(function (tooltipTriggerEl) {
                return new bootstrap.Tooltip(tooltipTriggerEl)
            })
        });
    </script>
}