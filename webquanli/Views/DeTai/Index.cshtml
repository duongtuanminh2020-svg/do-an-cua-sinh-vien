@model List<webquanli.Models.DeTai>
@{
    ViewData["Title"] = "Danh sách Đề Tài";
}

<div class="d-sm-flex align-items-center justify-content-between mb-4">
    <h1 class="h3 mb-0 text-gray-800">Danh sách Đề tài</h1>
    <a asp-action="Create" class="btn btn-primary text-white shadow-sm fw-bold">
        <i class="fa-solid fa-plus"></i> Thêm đề tài mới
    </a>
</div>

<div class="card shadow mb-4">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-bordered table-hover" id="dataTable" width="100%" cellspacing="0">
                <thead class="table-light">
                    <tr>
                        <th style="width: 5%;">ID</th>
                        <th style="width: 25%;">Tên Đề Tài</th>
                        <th style="width: 45%;">Mô Tả</th>
                        <th style="width: 15%;">Giảng Viên Phụ Trách</th>
                        <th style="width: 10%;" class="text-center">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var dt in Model)
                        {
                            <tr>
                                <td class="fw-bold align-middle">@dt.Id</td>
                                <td class="align-middle fw-bold text-primary">@dt.TenDeTai</td>
                                <td class="align-middle">@dt.MoTa</td>
                                <td class="align-middle text-center">
                                    <span class="badge bg-secondary">
                                        @(dt.GiangVien != null ? dt.GiangVien.TenGV : "Chưa phân công")
                                    </span>
                                </td>
                                <td class="text-center align-middle">
                                    <a asp-action="Edit" asp-route-id="@dt.Id" class="btn btn-warning btn-sm text-white">
                                        <i class="fa-solid fa-pen-to-square"></i>
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@dt.Id" class="btn btn-danger btn-sm" onclick="return confirm('Bạn có chắc chắn muốn xóa đề tài này?')">
                                        <i class="fa-solid fa-trash"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#dataTable').DataTable({ "language": { "url": "//cdn.datatables.net/plug-ins/1.13.6/i18n/vi.json" } });
        });
    </script>
}