@{
    ViewData["Title"] = "Đề Tài";
    string role = ViewBag.Role ?? "";
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show shadow-sm border-0" role="alert" style="background-color: #e5f8ed; color: #00b050;">
        <i class="fa-solid fa-circle-check"></i> <strong>Tuyệt vời!</strong> @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show shadow-sm border-0" role="alert" style="background-color: #ffe8eb; color: #f1416c;">
        <i class="fa-solid fa-triangle-exclamation"></i> <strong>Không thành công:</strong> @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (role == "sinhvien")
{
    string tenDeTai = ViewBag.TenDeTaiHienTai ?? "";
    string moTa = ViewBag.MoTaHienTai ?? "";
    string trangThai = ViewBag.TrangThai ?? "";
    string lyDo = ViewBag.LyDoTuChoi ?? "";
    bool daDangKy = !string.IsNullOrEmpty(tenDeTai);

    <div class="card shadow mb-4">
        <div class="card-header">
            <h6 class="m-0"><i class="fa-solid fa-book-open text-primary me-2"></i> ĐĂNG KÝ ĐỀ TÀI ĐỒ ÁN</h6>
        </div>
        <div class="card-body">
            @if (daDangKy)
            {
                @if (trangThai == "choduyet")
                {
                    <div class="alert border-0 mb-3" style="background-color: #fff8e1;">
                        <i class="fa-solid fa-hourglass-half text-warning me-2"></i>
                        <strong style="color: #f59e0b;">Đang chờ giảng viên phê duyệt...</strong>
                    </div>
                }
                else if (trangThai == "daduyet")
                {
                    <div class="alert border-0 mb-3" style="background-color: #e5f8ed;">
                        <i class="fa-solid fa-circle-check text-success me-2"></i>
                        <strong style="color: #00b050;">Đề tài đã được phê duyệt!</strong>
                    </div>
                }
                else if (trangThai == "tuchoi")
                {
                    <div class="alert border-0 mb-3" style="background-color: #ffe8eb;">
                        <i class="fa-solid fa-circle-xmark text-danger me-2"></i>
                        <strong style="color: #f1416c;">Đề tài bị từ chối!</strong>
                        @if (!string.IsNullOrEmpty(lyDo))
                        {
                            <div class="mt-2 text-danger">Lý do: @lyDo</div>
                        }
                    </div>
                }

                <div class="mb-3">
                    <label class="form-label fw-bold text-muted" style="font-size: 0.8rem;">TÊN ĐỀ TÀI</label>
                    <p class="fw-bold fs-6 mb-1">@tenDeTai</p>
                </div>
                @if (!string.IsNullOrEmpty(moTa))
                {
                    <div class="mb-3">
                        <label class="form-label fw-bold text-muted" style="font-size: 0.8rem;">MÔ TẢ</label>
                        <p class="text-muted mb-1">@moTa</p>
                    </div>
                }

                <hr />

                <div class="d-flex gap-2 mt-3">
                    @if (trangThai != "daduyet")
                    {
                        <button class="btn btn-outline-primary btn-sm" onclick="document.getElementById('formSuaDeTai').classList.toggle('d-none')">
                            <i class="fa-solid fa-pen me-1"></i> Chỉnh sửa
                        </button>
                        <form asp-action="XoaDeTai" method="post" onsubmit="return confirm('Bạn có chắc muốn xóa đề tài này?')">
                            <button type="submit" class="btn btn-outline-danger btn-sm">
                                <i class="fa-solid fa-trash me-1"></i> Xóa đề tài
                            </button>
                        </form>
                    }
                </div>

                <div id="formSuaDeTai" class="mt-3 d-none">
                    <form asp-action="LuuDeTai" method="post">
                        <div class="mb-3">
                            <label class="form-label fw-bold">Tên đề tài <span class="text-danger">*</span></label>
                            <input type="text" name="tenDeTai" class="form-control" value="@tenDeTai" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-bold">Mô tả</label>
                            <textarea name="moTa" class="form-control" rows="4" placeholder="Mô tả ý tưởng, công nghệ sử dụng, hướng thực hiện...">@moTa</textarea>
                        </div>
                        <button type="submit" class="btn btn-primary btn-sm">
                            <i class="fa-solid fa-paper-plane me-1"></i> Gửi lại để duyệt
                        </button>
                    </form>
                </div>
            }
            else
            {
                <p class="text-muted mb-3">Bạn chưa đăng ký đề tài. Hãy điền thông tin bên dưới và gửi cho giảng viên phê duyệt.</p>
                <form asp-action="LuuDeTai" method="post">
                    <div class="mb-3">
                        <label class="form-label fw-bold">Tên đề tài <span class="text-danger">*</span></label>
                        <input type="text" name="tenDeTai" class="form-control" placeholder="VD: Xây dựng hệ thống quản lý sinh viên..." required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Mô tả</label>
                        <textarea name="moTa" class="form-control" rows="4" placeholder="Mô tả ý tưởng, công nghệ sử dụng, hướng thực hiện..."></textarea>
                        <div class="form-text">Ghi rõ công nghệ, ngôn ngữ lập trình và hướng thực hiện để giảng viên dễ phê duyệt.</div>
                    </div>
                    <button type="submit" class="btn btn-primary">
                        <i class="fa-solid fa-paper-plane me-1"></i> Gửi đăng ký
                    </button>
                </form>
            }
        </div>
    </div>
}
else
{
    var danhSachSV = ViewBag.DanhSachSV as List<webquanli.Models.SinhVien> ?? new List<webquanli.Models.SinhVien>();
    var dsBoMon = danhSachSV.Where(s => s.BoMon != null).Select(s => s.BoMon.TenBoMon).Distinct().OrderBy(x => x).ToList();

    <div class="card shadow mb-4">
        <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
            <h6 class="m-0"><i class="fa-solid fa-book-open text-primary me-2"></i> DANH SÁCH ĐỀ TÀI SINH VIÊN</h6>
            <div class="d-flex align-items-center gap-2">
                @if (role == "admin")
                {
                    <select id="filterBoMon" class="form-select form-select-sm shadow-sm" style="width: 220px;">
                        <option value="">-- Vui lòng chọn Bộ môn --</option>
                        @foreach (var bm in dsBoMon)
                        {
                            <option value="@bm">@bm</option>
                        }
                    </select>
                }
                <span class="badge bg-primary">@danhSachSV.Count sinh viên</span>
            </div>
        </div>
        <div class="card-body">
            @if (!danhSachSV.Any())
            {
                <div class="text-center py-5">
                    <i class="fa-solid fa-folder-open text-muted mb-3" style="font-size: 4rem; opacity: 0.2;"></i>
                    <h6 class="text-muted">Chưa có sinh viên nào đăng ký đề tài</h6>
                </div>
            }
            else
            {
                <div id="tableWrapper" style="@(role == "admin" ? "display:none;" : "")">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle" id="dataTable">
                            <thead class="table-light text-muted" style="font-size: 0.85rem;">
                                <tr>
                                    <th>MSSV</th>
                                    <th>Họ và Tên</th>
                                    <th>Lớp</th>
                                    @if (role == "admin")
                                    {
                                        <th>Bộ môn</th>
                                    }
                                    <th>Tên đề tài</th>
                                    <th>Mô tả</th>
                                    <th class="text-center">Trạng thái</th>
                                    @if (role == "giangvien")
                                    {
                                        <th class="text-center">Thao tác</th>
                                    }
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var sv in danhSachSV)
                                {
                                    <tr>
                                        <td class="fw-bold text-muted">@sv.MaSV</td>
                                        <td class="fw-bold">@sv.TenSV</td>
                                        <td>@sv.Lop</td>
                                        @if (role == "admin")
                                        {
                                            <td><span class="badge bg-secondary">@sv.BoMon?.TenBoMon</span></td>
                                        }
                                        <td class="fw-bold text-primary">@sv.TenDeTai</td>
                                        <td style="max-width: 220px; font-size: 0.85rem;">
                                            <div class="mota-cell" style="max-height: 60px; overflow: hidden; color: #6b7280; line-height: 1.5;">@sv.MoTaDeTai</div>
                                            @if (!string.IsNullOrEmpty(sv.MoTaDeTai) && sv.MoTaDeTai.Length > 100)
                                            {
                                                <a href="#" class="text-primary" style="font-size: 0.78rem;" onclick="var c=this.previousElementSibling;c.style.maxHeight=c.style.maxHeight=='none'?'60px':'none';this.innerText=c.style.maxHeight=='none'?'Thu gọn':'Xem thêm';return false;">Xem thêm</a>
                                            }
                                        </td>
                                        <td class="text-center">
                                            @if (sv.TrangThaiDeTai == "daduyet")
                                            {
                                                <span class="badge bg-success"><i class="fa-solid fa-check me-1"></i> Đã duyệt</span>
                                            }
                                            else if (sv.TrangThaiDeTai == "tuchoi")
                                            {
                                                <span class="badge bg-danger"><i class="fa-solid fa-xmark me-1"></i> Từ chối</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-warning text-dark"><i class="fa-solid fa-hourglass-half me-1"></i> Chờ duyệt</span>
                                            }
                                        </td>
                                        @if (role == "giangvien")
                                        {
                                            <td class="text-center">
                                                @if (sv.TrangThaiDeTai != "daduyet")
                                                {
                                                    <div class="d-flex gap-1 justify-content-center">
                                                        <form asp-action="PheDuyet" method="post">
                                                            <input type="hidden" name="svId" value="@sv.Id" />
                                                            <button type="submit" class="btn btn-success btn-sm">
                                                                <i class="fa-solid fa-check"></i> Duyệt
                                                            </button>
                                                        </form>
                                                        <button type="button" class="btn btn-danger btn-sm"
                                                                onclick="document.getElementById('formTuChoi_@sv.Id').classList.toggle('d-none')">
                                                            <i class="fa-solid fa-xmark"></i> Từ chối
                                                        </button>
                                                    </div>
                                                    <div id="formTuChoi_@sv.Id" class="d-none mt-2">
                                                        <form asp-action="TuChoi" method="post">
                                                            <input type="hidden" name="svId" value="@sv.Id" />
                                                            <input type="text" name="lyDo" class="form-control form-control-sm mb-1" placeholder="Lý do từ chối..." />
                                                            <button type="submit" class="btn btn-danger btn-sm w-100">Xác nhận từ chối</button>
                                                        </form>
                                                    </div>
                                                }
                                                else
                                                {
                                                    <span class="text-muted" style="font-size: 0.8rem;"><i class="fa-solid fa-lock"></i> Đã chốt</span>
                                                }
                                            </td>
                                        }
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }
        </div>
    </div>
}

@section Scripts {
    <script>
        $(document).ready(function () {
            var table = $('#dataTable').DataTable({
                "language": { "url": "//cdn.datatables.net/plug-ins/1.13.6/i18n/vi.json" },
                "pageLength": 10
            });

            @if (role == "admin")
            {
                        <text>
                                $('#filterBoMon').on('change', function () {
                                    var val = $(this).val();
                                    if (val === "") {
                                        $('#tableWrapper').hide();
                                        table.column(3).search("").draw();
                                    } else {
                                        $('#tableWrapper').show();
                                        table.column(3).search(val).draw();
                                    }
                                });
                        </text>
            }
        });
    </script>
}
