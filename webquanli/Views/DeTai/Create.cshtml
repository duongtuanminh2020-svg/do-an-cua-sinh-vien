@model webquanli.Models.DeTai
@{
    ViewData["Title"] = "Thêm Đề Tài";
}

<div class="d-sm-flex align-items-center justify-content-between mb-4">
    <h1 class="h3 mb-0 text-gray-800">Thêm Đề Tài Mới</h1>
    <a asp-action="Index" class="btn btn-secondary shadow-sm">
        Quay lại danh sách
    </a>
</div>

<div class="card shadow mb-4">
    <div class="card-body">
        <form asp-action="Create" method="post">
            <div class="mb-3">
                <label class="form-label fw-bold">Tên Đề Tài</label>
                <input asp-for="TenDeTai" class="form-control" required placeholder="Nhập tên đề tài..." />
            </div>
            
            <div class="mb-3">
                <label class="form-label fw-bold">Mô Tả</label>
                <textarea asp-for="MoTa" class="form-control" rows="4" placeholder="Nhập mô tả chi tiết..."></textarea>
            </div>

            <div class="mb-3">
                <label class="form-label fw-bold">Giảng Viên Phụ Trách</label>
                <select asp-for="GiangVienId" class="form-select" asp-items="ViewBag.GiangVienId" required>
                    <option value="">-- Chọn Giảng Viên --</option>
                </select>
            </div>

            <div class="mt-4">
                <button type="submit" class="btn btn-primary fw-bold px-4">
                    Lưu Đề Tài
                </button>
            </div>
        </form>
    </div>
</div>