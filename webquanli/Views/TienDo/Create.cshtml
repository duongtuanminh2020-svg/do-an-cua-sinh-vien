@model webquanli.Models.TienDo
@{
    ViewData["Title"] = "Thêm Tiến Độ";
}

<div class="card shadow mb-4" style="max-width: 800px; margin: auto; margin-top: 50px;">
    <div class="card-header py-3 bg-info text-center">
        <h6 class="m-0 font-weight-bold text-white text-uppercase">Cập Nhật Tiến Độ Mới</h6>
    </div>
    <div class="card-body">
        <form asp-action="Create" method="post">
            <div class="mb-3">
                <label class="form-label fw-bold">Chọn Sinh viên & Đề tài</label>
                <select asp-for="DangKyId" class="form-select" asp-items="ViewBag.DanhSachDangKy" required>
                    <option value="">-- Vui lòng chọn nhóm --</option>
                </select>
            </div>

            <div class="mb-3">
                <label class="form-label fw-bold">Nội dung công việc</label>
                <textarea asp-for="NoiDung" class="form-control" rows="4" required placeholder="Nhập những công việc bạn đã hoàn thành..."></textarea>
            </div>

            <div class="mb-3">
                <label class="form-label fw-bold">Tiến độ hoàn thành (%)</label>
                <input asp-for="PhanTram" type="number" class="form-control" min="0" max="100" required placeholder="Ví dụ: 50" />
            </div>

            <hr />
            <button type="submit" class="btn btn-info w-100 fw-bold text-white">
                <i class="fa-solid fa-plus"></i> LƯU TIẾN ĐỘ
            </button>
            <a asp-action="Index" class="btn btn-secondary w-100 mt-2">Quay lại danh sách</a>
        </form>
    </div>
</div>