@model IEnumerable<webquanli.Models.BoMon>
@{
    ViewData["Title"] = "Quản lý Bộ Môn";
}

<div class="d-sm-flex align-items-center justify-content-between mb-4">
    <h1 class="h3 mb-0 text-gray-800">Quản lý Bộ Môn (Khoa CNTT)</h1>
    <a asp-action="Create" class="btn btn-primary shadow-sm fw-bold">
        <i class="fa-solid fa-plus"></i> Thêm Bộ môn mới
    </a>
</div>

<div class="card shadow mb-4 border-left-primary">
    <div class="card-body">
        <table class="table table-bordered table-hover">
            <thead class="table-light">
                <tr>
                    <th class="text-center" style="width: 10%;">Mã số</th>
                    <th>Tên Bộ Môn</th>
                    <th class="text-center" style="width: 15%;">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="text-center fw-bold">@item.Id</td>
                        <td><span class="badge bg-info text-dark fs-6">@item.TenBoMon</span></td>
                        <td class="text-center">
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm" onclick="return confirm('Xóa bộ môn này?');">
                                <i class="fa-solid fa-trash"></i> Xóa
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>