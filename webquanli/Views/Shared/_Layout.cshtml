<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Quản lý đồ án</title>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />

    <style>
            body {
                margin: 0;
                font-family: Arial, Helvetica, sans-serif;
            }

            .sidebar {
                width: 240px;
                height: 100vh;
                position: fixed;
                background: #343a40;
                color: white;
            }

                .sidebar h2 {
                    padding: 20px;
                    text-align: center;
                    border-bottom: 1px solid #555;
                }

                .sidebar a {
                    display: block;
                    padding: 15px 20px;
                    color: white;
                    text-decoration: none;
                }

                    .sidebar a:hover {
                        background: #495057;
                    }

            .content {
                margin-left: 240px;
                padding: 25px;
            }
    </style>
</head>

<body>

    <!-- MENU BÊN TRÁI -->
    <div class="sidebar">

        <h2>QUẢN LÝ</h2>

        <a asp-controller="Home" asp-action="Index">Dashboard</a>

        <a asp-controller="SinhVien" asp-action="Index">Sinh viên</a>

        <a asp-controller="DeTai" asp-action="Index">Đề tài</a>

        <a asp-controller="TienDo" asp-action="Index">Tiến độ</a>

        <a asp-controller="BaoCao" asp-action="Index">Báo cáo</a>

        <a asp-controller="Account" asp-action="Logout">Đăng xuất</a>

    </div>

    <!-- NỘI DUNG -->
    <div class="content">

        @RenderBody()

    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

    @RenderSection("Scripts", required: false)

</body>
</html>