@using webquanli.Data
@inject ApplicationDbContext _context
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Quản Lý Đồ Án</title>

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css" />
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css" />

    <style>
        :root {
            --primary-color: #4361ee;
            --sidebar-bg: #ffffff;
            --bg-body: #f4f7fe;
            --text-main: #2b3674;
            --text-muted: #8f9bba;
            --border-soft: #e9edf7;
        }

        body { 
            font-family: 'Inter', sans-serif;
            background-color: var(--bg-body); 
            color: var(--text-main);
            margin: 0; 
            overflow-x: hidden; 
        }

        .sidebar { 
            width: 260px;
            height: 100vh; position: fixed; 
            background: var(--sidebar-bg); 
            color: var(--text-main); 
            box-shadow: 4px 0 25px rgba(0,0,0,0.04);
            z-index: 1000;
            overflow-y: auto;
        }
        
        .sidebar::-webkit-scrollbar { width: 5px; }
        .sidebar::-webkit-scrollbar-thumb { background: #e2e8f0; border-radius: 5px; }

        .sidebar-brand { 
            padding: 25px 20px;
            font-size: 1.3rem; font-weight: 800; 
            text-align: center; color: var(--text-main); text-decoration: none; 
            display: flex; align-items: center; justify-content: center; gap: 10px;
            border-bottom: 1px dashed var(--border-soft);
        }
        .sidebar-brand i { color: var(--primary-color); font-size: 1.6rem; }
        
        .sidebar-menu { padding: 25px 0; display: flex; flex-direction: column; gap: 8px; }

        .sidebar-menu a { 
            display: flex; align-items: center; padding: 12px 15px; margin: 0 16px; 
            color: var(--text-muted); text-decoration: none; transition: all 0.3s ease; 
            font-weight: 600; font-size: 0.95rem; border-radius: 12px;
        }
        
        .sidebar-menu a i { width: 35px; font-size: 1.15rem; transition: 0.3s; }
        .sidebar-menu a:hover { background: #f8f9fa; color: var(--text-main); transform: translateX(3px); }
        .sidebar-menu a.active { background: var(--primary-color); color: #fff; box-shadow: 0 6px 15px rgba(67, 97, 238, 0.25); }
        .sidebar-menu a.active i { color: #fff !important; }

        .sidebar-menu .submenu { background: transparent; padding: 5px 0; }
        .sidebar-menu .submenu a { padding-left: 50px; margin-top: 2px; font-size: 0.9rem; color: var(--text-muted); }
        .sidebar-menu .submenu a:hover { background: #f8f9fa; }
        .sidebar-menu .submenu a.active { background: #eef2ff; color: var(--primary-color); box-shadow: none; }
        .sidebar-menu .submenu a.active i { color: var(--primary-color) !important; }
        .sidebar-menu a[aria-expanded="true"] .arrow-icon { transform: rotate(180deg); }

        .main-wrapper { margin-left: 260px; min-height: 100vh; display: flex; flex-direction: column; }
        .topbar { height: 75px; background: rgba(255, 255, 255, 0.9); backdrop-filter: blur(10px); display: flex; align-items: center; justify-content: flex-end; padding: 0 30px; position: sticky; top: 0; z-index: 999; }
        .content { padding: 30px; flex-grow: 1; }

        .card { border: none; box-shadow: 0px 4px 20px rgba(0, 0, 0, 0.03); border-radius: 16px; background: #fff; }
        .card-header { background-color: #fff; border-bottom: 1px dashed var(--border-soft); padding: 20px 25px; border-radius: 16px 16px 0 0 !important; }
        .card-header h6 { font-size: 1.1rem; font-weight: 700 !important; color: var(--text-main) !important; }
        
        .table-responsive { padding: 10px 25px 25px 25px; }
        .table { margin-bottom: 0; }
        .table-bordered > :not(caption) > * > * { border-width: 0; } 
        .table thead th { background: #f8f9fa; color: var(--text-muted); font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.5px; border-bottom: none; padding: 15px; font-weight: 700; }
        .table tbody td { vertical-align: middle; padding: 16px 15px; color: var(--text-main); font-weight: 500; border-bottom: 1px dashed var(--border-soft); }
        
        .btn { border-radius: 8px; font-weight: 600; padding: 8px 16px; transition: 0.3s; }
        .btn-sm { padding: 6px 12px; font-size: 0.8rem; border-radius: 6px; }
        .btn-primary { background-color: var(--primary-color); border-color: var(--primary-color); }
        .btn-primary:hover { background-color: #344dd9; transform: translateY(-1px); box-shadow: 0 4px 10px rgba(67, 97, 238, 0.3); }
        
        .badge { padding: 6px 10px; border-radius: 6px; font-weight: 600; letter-spacing: 0.3px; }
        .badge.bg-success { background-color: #e5f8ed !important; color: #00b050 !important; border: 1px solid #d1f3e0; }
        .badge.bg-danger { background-color: #ffe8eb !important; color: #f1416c !important; border: 1px solid #fcdbdc; }
        .badge.bg-primary { background-color: #eef2ff !important; color: #4361ee !important; border: 1px solid #e0e7ff; }
    </style>
</head>
<body>
    @{
        string realRole = "";
        var currentUsername = "";
        var dsThongBao = new List<webquanli.Models.ThongBao>();
        int soThongBaoChuaDoc = 0;

        if (User.Identity.IsAuthenticated)
        {
            currentUsername = User.Identity.Name;
            var currentUser = _context.Users.FirstOrDefault(u => u.Username == currentUsername);
            if (currentUser != null && !string.IsNullOrEmpty(currentUser.Role))
            {
                realRole = currentUser.Role.Trim().ToLower();
            }

            dsThongBao = _context.ThongBaos
                .Where(t => t.UsernameNhan == currentUsername)
                .OrderByDescending(t => t.NgayTao)
                .Take(10)
                .ToList();
            soThongBaoChuaDoc = dsThongBao.Count(t => t.DaDoc == false);
        }
    }

    <div class="sidebar">
        <a href="/" class="sidebar-brand">
            <i class="fa-solid fa-graduation-cap"></i> QUẢN LÝ ĐỒ ÁN
        </a>
        <div class="sidebar-menu">
            
            @if (realRole == "admin")
            {
                <a asp-controller="Home" asp-action="Index"><i class="fa-solid fa-chart-pie" style="color: #4361ee;"></i> Dashboard</a>
            }
            <a asp-controller="Profile" asp-action="Index"><i class="fa-solid fa-address-card" style="color: #20c997;"></i> Hồ sơ cá nhân</a>

            @if (realRole == "admin")
            {
                <a asp-controller="BoMon" asp-action="Index"><i class="fa-solid fa-building-columns" style="color: #f59e0b;"></i> Bộ môn</a>
            }

            @if (realRole == "admin" || realRole == "giangvien")
            {
                <a class="nav-link collapsed" data-bs-toggle="collapse" href="#collapseDanhSach" aria-expanded="false" style="justify-content: space-between;">
                    <div class="d-flex align-items-center">
                        <i class="fa-solid fa-users-viewfinder" style="color: #0dcaf0;"></i> Danh sách
                    </div>
                    <i class="fa-solid fa-chevron-down arrow-icon text-muted" style="font-size: 0.75rem;"></i>
                </a>
                
                <div class="collapse" id="collapseDanhSach">
                    <div class="submenu">
                        @if (realRole == "admin")
                        {
                            <a asp-controller="GiangVien" asp-action="Index"><i class="fas fa-fw fa-chalkboard-teacher" style="color: #8b5cf6;"></i> Giảng viên</a>
                        }
                        <a asp-controller="SinhVien" asp-action="Index"><i class="fa-solid fa-user-graduate" style="color: #ec4899;"></i> Sinh viên</a>
                    </div>
                </div>
            }

            <a asp-controller="DeTai" asp-action="Index"><i class="fa-solid fa-book" style="color: #ef4444;"></i> Đề tài</a>
            <a asp-controller="TienDo" asp-action="Index"><i class="fa-solid fa-tasks" style="color: #14b8a6;"></i> Tiến độ</a>
            <a asp-controller="BaoCao" asp-action="Index"><i class="fa-solid fa-file-arrow-up" style="color: #3b82f6;"></i> Báo cáo</a>
            
        </div>
    </div>

    <div class="main-wrapper">
        <div class="topbar">
            <div class="dropdown me-4">
                <button class="btn btn-light border shadow-sm position-relative d-flex align-items-center justify-content-center" type="button" data-bs-toggle="dropdown" aria-expanded="false" style="width: 40px; height: 40px; border-radius: 50%;">
                    <i class="fa-solid fa-bell text-warning fs-5"></i>
                    @if (soThongBaoChuaDoc > 0)
                    {
                        <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger shadow" style="font-size: 0.65rem;">
                            @soThongBaoChuaDoc
                        </span>
                    }
                </button>
        
                <ul class="dropdown-menu dropdown-menu-end shadow border-0" style="width: 360px; max-height: 450px; overflow-y: auto; padding: 0; z-index: 9999;">
                    <li class="p-3 border-bottom d-flex justify-content-between align-items-center bg-primary text-white" style="border-radius: 5px 5px 0 0;">
                        <span class="fw-bold"><i class="fa-solid fa-envelope-open-text me-2"></i> Thông báo</span>
                        @if (soThongBaoChuaDoc > 0)
                        {
                            <form asp-controller="ThongBao" asp-action="DanhDauDaDoc" method="post" class="m-0">
                                <button type="submit" class="btn btn-sm btn-light text-primary fw-bold" style="font-size: 11px;">Đánh dấu đã đọc</button>
                            </form>
                        }
                    </li>
                    @if (dsThongBao.Count == 0)
                    {
                        <li class="p-4 text-center text-muted">
                            <i class="fa-regular fa-bell-slash fs-3 mb-2 opacity-50"></i><br>
                            <small>Hiện tại không có thông báo nào.</small>
                        </li>
                    }
                    else
                    {
                        foreach (var tb in dsThongBao)
                        {
                            string bgClass = tb.DaDoc ? "bg-white" : "bg-light border-start border-4 border-warning";
                            string textClass = tb.DaDoc ? "text-muted" : "text-dark";
                            <li class="p-3 border-bottom @bgClass position-relative">
                                <div class="d-flex justify-content-between mb-1 pe-4">
                                    <h6 class="mb-0 fw-bold @textClass" style="font-size: 13px;">@tb.TieuDe</h6>
                                    <small class="text-secondary" style="font-size: 11px;">@tb.NgayTao.ToString("dd/MM HH:mm")</small>
                                </div>
                                <p class="mb-0 @textClass" style="font-size: 12px; line-height: 1.4; padding-right: 20px;">@tb.NoiDung</p>
                                <form asp-controller="ThongBao" asp-action="Xoa" asp-route-id="@tb.Id" method="post" class="position-absolute" style="top: 12px; right: 12px;">
                                    <button type="submit" class="btn btn-sm text-danger p-0 border-0 bg-transparent opacity-50 hover-opacity-100" title="Xóa">
                                        <i class="fa-solid fa-xmark fs-5"></i>
                                    </button>
                                </form>
                            </li>
                        }
                    }
                </ul>
            </div>
            
            <div class="dropdown">
                <button class="btn btn-light dropdown-toggle border shadow-sm" type="button" data-bs-toggle="dropdown">
                    <i class="fa-solid fa-circle-user text-primary me-1"></i> 
                    <strong>@User.Identity.Name</strong> 
                </button>
                <ul class="dropdown-menu dropdown-menu-end shadow border-0">
                    <li class="px-3 py-2">
                        <small class="text-muted d-block text-uppercase fw-bold" style="font-size: 10px;">Vai trò</small>
                        <span class="badge bg-soft-primary text-primary border border-primary">
                            @if (realRole == "admin") { <span>Quản trị viên</span> }
                            else if (realRole == "giangvien") { <span>Giảng viên</span> }
                            else { <span>Sinh viên</span> }
                        </span>
                    </li>
                    <li><hr class="dropdown-divider"></li>
                    <li>
                        <a class="dropdown-item" asp-controller="Profile" asp-action="Index">
                            <i class="fa-solid fa-address-card me-2 text-primary"></i> Hồ sơ cá nhân
                        </a>
                    </li>
                    <li>
                        <a class="dropdown-item text-danger" asp-controller="Account" asp-action="Logout">
                            <i class="fa-solid fa-right-from-bracket me-2"></i> Đăng xuất
                        </a>
                    </li>
                </ul>
            </div>
        </div>

        <div class="content">
            @RenderBody()
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.7.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>

    <script>
        $(document).ready(function() {
            var path = window.location.pathname.toLowerCase();
            if (path === "/" || path === "") path = "/home";

            $('.sidebar-menu a').each(function () {
                var href = $(this).attr('href');
                if (href && href !== "#") {
                    var hrefLower = href.toLowerCase();
                    if (path === hrefLower || path.startsWith(hrefLower + '/')) {
                        $(this).addClass('active');
                        var parentCollapse = $(this).closest('.collapse');
                        if (parentCollapse.length > 0) {
                            parentCollapse.addClass('show');
                            parentCollapse.prev('a').attr('aria-expanded', 'true');
                        }
                    }
                }
            });
        });
    </script>

    @RenderSection("Scripts", required: false)
</body>
</html>