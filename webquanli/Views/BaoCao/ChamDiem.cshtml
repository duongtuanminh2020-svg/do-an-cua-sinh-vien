@model webquanli.Models.BaoCao
@{
    ViewData["Title"] = "Nhận xét Báo Cáo";
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card shadow-sm border-0 mb-4" style="border-radius: 16px;">
            <div class="card-header bg-white py-3 border-bottom">
                <h6 class="m-0 fw-bold text-primary">
                    <i class="fa-solid fa-comment-dots me-2"></i> Nhận xét Báo Cáo Đồ Án
                </h6>
            </div>
            <div class="card-body p-4">

                <div class="p-3 rounded-3 mb-4" style="background: #eff6ff; border: 1px solid #bfdbfe;">
                    <p class="mb-1"><strong>Sinh viên:</strong> @Model.DangKyDeTai.SinhVien.TenSV</p>
                    <p class="mb-1"><strong>Lớp:</strong> @Model.DangKyDeTai.SinhVien.Lop</p>
                    <p class="mb-1"><strong>Đề tài:</strong> @Model.DangKyDeTai.DeTai.TenDeTai</p>
                    <p class="mb-0">
                        <strong>File báo cáo:</strong>
                        <a asp-action="Download" asp-route-id="@Model.Id" class="text-decoration-none fw-bold text-primary ms-1">
                            <i class="fa-solid fa-download me-1"></i> Tải @Model.TenFile về xem
                        </a>
                    </p>
                </div>

                <form asp-action="ChamDiem" method="post">
                    <input type="hidden" name="id" value="@Model.Id" />
                    <input type="hidden" name="Diem" value="@Model.Diem" />

                    <div class="mb-4">
                        <label class="form-label fw-bold">Lời nhận xét / Góp ý:</label>
                        <textarea name="NhanXet" class="form-control" rows="6" placeholder="Nhập lời nhận xét, góp ý cho sinh viên...">@Model.NhanXet</textarea>
                    </div>

                    <div class="d-flex justify-content-end gap-2">
                        <a asp-action="Index" class="btn btn-secondary" style="border-radius: 8px;">
                            <i class="fa-solid fa-arrow-left me-1"></i> Quay lại
                        </a>
                        <button type="submit" class="btn btn-primary fw-bold" style="border-radius: 8px;">
                            <i class="fa-solid fa-floppy-disk me-1"></i> Lưu nhận xét
                        </button>
                    </div>
                </form>

            </div>
        </div>
    </div>
</div>
