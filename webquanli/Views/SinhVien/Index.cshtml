@model IEnumerable<webquanli.Models.SinhVien>
@{
    ViewData["Title"] = "Danh sách Sinh Viên";
}

<div class="d-sm-flex align-items-center justify-content-between mb-4">
    <h1 class="h3 mb-0 text-gray-800">
        @(User.IsInRole("GiangVien") ? "Danh sách Sinh Viên Lớp Quản Lý" : "Toàn bộ Sinh Viên")
    </h1>

    @if (User.IsInRole("Admin"))
    {
        <a asp-action="Create" class="btn btn-primary text-white shadow-sm fw-bold">
            + Thêm sinh viên mới
        </a>
    }
</div>

<div class="card shadow mb-4">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-bordered table-hover" id="dataTable" width="100%" cellspacing="0">
                <thead class="table-light">
                    <tr>
                        <th>Mã SV</th>
                        <th>Họ và Tên</th>
                        <th>Lớp</th>
                        <th>Email</th>
                        @if (User.IsInRole("Admin"))
                        {
                            <th class="text-center">Thao tác</th>
                        }
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="fw-bold">@item.MaSV</td>
                            <td>@item.TenSV</td>
                            <td><span class="badge bg-info">@item.Lop</span></td>
                            <td>@item.Email</td>
                            
                            @if (User.IsInRole("Admin"))
                            {
                                <td class="text-center">
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm text-white">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm" onclick="return confirm('Xác nhận xóa sinh viên này?')">
                                        <i class="fas fa-trash"></i>
                                    </a>
                                </td>
                            }
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>