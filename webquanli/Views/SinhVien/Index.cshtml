@model List<webquanli.Models.SinhVien>
@{
    ViewData["Title"] = "Danh sách sinh viên";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="m-0 text-gray-800">Danh sách Sinh Viên</h3>
    <a class="btn btn-primary shadow-sm" href="/SinhVien/Create">
        <i class="fa-solid fa-plus fa-sm text-white-50"></i> Thêm sinh viên mới
    </a>
</div>

<div class="card shadow mb-4">
    <div class="card-header py-3">
        <h6 class="m-0 font-weight-bold text-primary">Dữ liệu sinh viên khoa CNTT</h6>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-bordered table-hover" id="dataTable" width="100%" cellspacing="0">
                <thead class="table-light">
                    <tr>
                        <th>Mã SV</th>
                        <th>Họ và Tên</th>
                        <th>Lớp</th>
                        <th>Email</th>
                        <th class="text-center" style="width: 150px;">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var sv in Model)
                    {
                        <tr>
                            <td class="align-middle"><strong>@sv.MaSV</strong></td>
                            <td class="align-middle">@sv.TenSV</td>
                            <td class="align-middle"><span class="badge bg-info text-dark">@sv.Lop</span></td>
                            <td class="align-middle">@sv.Email</td>
                            <td class="text-center align-middle">
                                <a class="btn btn-warning btn-sm" href="/SinhVien/Edit/@sv.Id" title="Sửa">
                                    <i class="fa-solid fa-pen-to-square"></i>
                                </a>
                                <a class="btn btn-danger btn-sm" href="/SinhVien/Delete/@sv.Id" title="Xóa">
                                    <i class="fa-solid fa-trash"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            // Kích hoạt DataTables với cấu hình tiếng Việt
            $('#dataTable').DataTable({
                "language": {
                    "url": "//cdn.datatables.net/plug-ins/1.13.6/i18n/vi.json"
                }
            });
        });
    </script>
}