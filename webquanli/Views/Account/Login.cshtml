@{
    // Tắt thanh menu Layout chính cho trang đăng nhập
    Layout = null; 
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Đăng nhập - Đồ án HUTECH</title>
    
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700;800&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css" />

    <style>
        :root {
            --primary-color: #0033a0; /* Màu xanh HUTECH */
            --primary-hover: #002277;
            --text-main: #2b3674;
            --text-muted: #a3aed1;
        }

        body {
            font-family: 'Inter', sans-serif;
            margin: 0;
            padding: 0;
            height: 100vh;
            overflow: hidden;
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
        }

        /* --- PHẦN HÌNH NỀN PHÍA SAU (Rõ Nét) --- */
        .page-background {
            position: fixed;
            top: 0; left: 0; right: 0; bottom: 0;
            background-image: url('/img/bgtruong.webp'); /* Đã khớp tên file của bạn */
            background-size: cover;
            background-position: center;
            filter: blur(2px) scale(1.05); /* Giữ mờ nhẹ như ý bạn */
            transform: scale(1.05); 
            z-index: 1;
        }

        /* Lớp mờ màu xanh HUTECH siêu nhạt */
        .overlay {
            position: fixed;
            top: 0; left: 0; right: 0; bottom: 0;
            background: linear-gradient(135deg, rgba(0, 51, 160, 0.3) 0%, rgba(20, 30, 90, 0.1) 100%);
            z-index: 2;
        }

        /* --- PHẦN LOGO GÓC TRÊN BÊN PHẢI (NÂNG CẤP SIÊU TO) --- */
        .top-right-logo-container {
            position: fixed;
            top: 30px; /* Điều chỉnh lại vị trí cho logo lớn */
            right: 30px; /* Ở góc phải */
            z-index: 999;
            display: flex;
            align-items: center;
            justify-content: center;
            backdrop-filter: blur(5px); /* Hiệu ứng kính mờ xung quanh logo lớn */
            background: rgba(255, 255, 255, 0.15); /* Tăng độ mờ một chút cho logo nổi bật */
            padding: 15px 25px; /* Tăng padding cho logo lớn */
            border-radius: 15px;
            border: 1px solid rgba(255, 255, 255, 0.1);
            box-shadow: 0 5px 15px rgba(0,0,0,0.05);
        }

        .hutech-official-logo {
            height: 100px; /* NÂNG CẤP KÍCH CỠ TỪ 50PX LÊN 100PX (Gấp đôi) */
            max-width: auto;
            display: block;
        }

        /* --- PHẦN Ô ĐĂNG NHẬP --- */
        .login-card-container {
            position: relative;
            z-index: 10;
            display: flex;
            justify-content: center;
            align-items: center;
            width: 100%;
            height: 100%;
        }

        .login-card {
            width: 100%;
            max-width: 400px; 
            background-color: rgba(255, 255, 255, 0.85); 
            border-radius: 20px; 
            box-shadow: 0 10px 30px rgba(0,0,0,0.1); 
            padding: 40px;
            border: 1px solid rgba(255, 255, 255, 0.1);
        }

        .card-brand-icon {
            width: 60px;
            height: 60px;
            background: rgba(0, 51, 160, 0.1);
            color: var(--primary-color);
            border-radius: 16px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 28px;
            margin-bottom: 20px;
        }

        .card-title {
            font-weight: 800;
            color: var(--text-main);
            font-size: 1.8rem;
            margin-bottom: 5px;
        }

        .card-subtitle {
            color: var(--text-muted);
            font-size: 0.95rem;
            margin-bottom: 30px;
        }

        /* --- PHẦN FORM NHẬP LIỆU --- */
        .form-label {
            font-weight: 600;
            color: var(--text-main);
            font-size: 0.85rem;
            margin-bottom: 8px;
        }

        .input-group {
            border-radius: 12px;
            overflow: hidden;
            background-color: #f8f9fa;
            border: 1px solid #e9edf7;
            transition: all 0.3s;
        }

        .input-group:focus-within {
            background-color: #fff;
            border-color: var(--primary-color);
            box-shadow: 0 0 0 4px rgba(0, 51, 160, 0.1);
        }

        .input-group-text {
            border-radius: 0;
            border: none;
            background-color: transparent;
            color: var(--text-muted);
            padding: 14px 18px;
        }
        
        .form-control {
            border-radius: 0;
            padding: 14px 18px 14px 5px;
            border: none;
            font-size: 0.95rem;
            background-color: transparent;
        }

        .form-control:focus {
            box-shadow: none;
        }

        /* --- PHẦN NÚT BẤM VÀ CÁC THÀNH PHẦN PHỤ --- */
        .btn-login {
            background-color: var(--primary-color);
            color: white;
            border: none;
            border-radius: 12px;
            padding: 14px;
            font-weight: 700;
            font-size: 1rem;
            width: 100%;
            transition: all 0.3s;
            margin-top: 15px;
            box-shadow: 0 4px 15px rgba(0, 51, 160, 0.2);
        }

        .btn-login:hover {
            background-color: var(--primary-hover);
            transform: translateY(-1px);
            box-shadow: 0 6px 20px rgba(0, 51, 160, 0.3);
        }

        .form-check-label {
            color: #6b7280;
            font-size: 0.85rem;
        }

        .forgot-password-link {
            font-size: 0.8rem;
            font-weight: 600;
            color: var(--primary-color);
            text-decoration: none;
        }

        /* --- RESPONSIVE MOBILE: Gom cho điện thoại --- */
        @@media (max-width: 992px) {
            .top-right-logo-container { display: none; } /* Giấu logo góc phải trên mobile cho gọn */
            .page-background { filter: none; transform: none; } /* Tắt mờ nhẹ trên mobile */
            .overlay { background: linear-gradient(135deg, rgba(0, 51, 160, 0.6) 0%, rgba(20, 30, 90, 0.4) 100%); } /* Tăng độ mờ trên mobile để dễ đọc */
            .login-card { padding: 30px; border-radius: 16px; margin: 0 15px; background-color: rgba(255, 255, 255, 0.9); }
            .card-title { font-size: 1.5rem; }
        }
    </style>
</head>
<body>

    <div class="page-background"></div>
    <div class="overlay"></div>

    <div class="top-right-logo-container">
        <img src="/img/logotruong.jpg" class="hutech-official-logo" alt="Official HUTECH Logo" />
    </div>

    <div class="login-card-container">
        <div class="login-card shadow-lg">
            
            <div class="d-flex flex-column align-items-center mb-4">
                <div class="card-brand-icon">
                    <i class="fa-solid fa-graduation-cap"></i>
                </div>
                
                <h2 class="card-title text-center">HUTECH</h2>
                <h6 class="card-subtitle text-center">Hệ Thống Quản Lý Đồ Án</h6>
            </div>

            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger d-flex align-items-center py-2 px-3 mb-4" style="border-radius: 12px; font-size: 0.85rem;" role="alert">
                    <i class="fa-solid fa-circle-exclamation me-2"></i>
                    <div>@TempData["Error"]</div>
                </div>
            }

            <form asp-controller="Account" asp-action="Login" method="post">
                
                <div class="mb-3">
                    <label class="form-label">Tên đăng nhập / Mã số</label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="fa-regular fa-user"></i></span>
                        <input type="text" name="Username" class="form-control" placeholder="Nhập mã SV hoặc mã GV" required autofocus>
                    </div>
                </div>

                <div class="mb-4">
                    <div class="d-flex justify-content-between mb-1">
                        <label class="form-label mb-0">Mật khẩu</label>
                        <a href="#" class="forgot-password-link">Quên mật khẩu?</a>
                    </div>
                    <div class="input-group">
                        <span class="input-group-text"><i class="fa-solid fa-lock"></i></span>
                        <input type="password" name="Password" class="form-control" placeholder="••••••••" required>
                    </div>
                </div>

                <div class="form-check mb-4">
                    <input class="form-check-input" type="checkbox" value="" id="rememberMe">
                    <label class="form-check-label" for="rememberMe">
                        Ghi nhớ đăng nhập
                    </label>
                </div>

                <button type="submit" class="btn-login">
                    ĐĂNG NHẬP <i class="fa-solid fa-arrow-right ms-2"></i>
                </button>
            </form>

            <div class="text-center mt-5" style="font-size: 0.75rem; color: #a3aed1; opacity: 0.7;">
                &copy; 2024 Khoa CNTT - Đồ án HUTECH.
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>